<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="650.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.photo.editor.EditorController">
   <center>
      <StackPane prefHeight="150.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <children>
            <ImageView fx:id="editImageView" fitHeight="500.0" fitWidth="800.0" pickOnBounds="true" preserveRatio="true" />
            <AnchorPane fx:id="drawPane" prefHeight="500.0" prefWidth="800.0" />
         </children>
      </StackPane>
   </center>
   <bottom>
      <VBox prefHeight="100.0" prefWidth="100.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <children>
            <HBox fx:id="colorPanel" prefHeight="100.0" prefWidth="200.0" visible="false">
               <children>
                  <Button mnemonicParsing="false" onAction="#selectRed" text="Button" />
                  <Button mnemonicParsing="false" onAction="#selectOrange" text="Button" />
                  <Button mnemonicParsing="false" onAction="#selectYellow" text="Button" />
                  <Button mnemonicParsing="false" onAction="#selectGreen" text="Button" />
                  <Button mnemonicParsing="false" onAction="#selectCyan" text="Button" />
                  <Button mnemonicParsing="false" onAction="#selectBlue" text="Button" />
                  <Button mnemonicParsing="false" onAction="#selectPurple" text="Button" />
               </children>
            </HBox>
            <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="10.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#toggleColorPanel" text="画笔" />
                  <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="5.0">
                     <children>
                        <Label text="粗细" />
                        <Slider fx:id="thicknessSlider" max="20.0" min="1.0" value="2.0" />
                        <Separator orientation="VERTICAL" prefHeight="200.0" />
                     </children>
                  </HBox>
                  <Button mnemonicParsing="false" onAction="#applySharpen" text="锐化" />
                  <Button mnemonicParsing="false" onAction="#applyBlur" text="模糊" />
                  <Button mnemonicParsing="false" onAction="#applyBrightness" text="亮度" />
                  <Button mnemonicParsing="false" onAction="#applyContrast" text="对比度" />
                  <Separator orientation="VERTICAL" prefHeight="200.0" />
                  <Button mnemonicParsing="false" onAction="#saveImage" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="保存" />
               </children>
            </HBox>
         </children>
      </VBox>
   </bottom>
</BorderPane>
