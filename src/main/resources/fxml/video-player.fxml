<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.media.MediaView?>

<?import javafx.scene.control.Label?>
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.photo.controller.VideoPlayerController"
            prefWidth="800" prefHeight="600">

    <!-- 中间视频播放区 -->
    <center>
        <StackPane>
            <MediaView fx:id="videoView" />
        </StackPane>
    </center>

    <!-- 底部控制栏 -->
    <bottom>
        <HBox spacing="10" padding="10" alignment="CENTER">
            <Button fx:id="playBtn" text="播放" prefWidth="80"/>
            <Button fx:id="pauseBtn" text="暂停" prefWidth="80"/>
            <Slider fx:id="videoSlider" min="0" max="100" prefWidth="300"/>
            <Label text="音量"/>
            <Slider fx:id="volumeSlider" min="0" max="1" prefWidth="100"/>
            <Button fx:id="closeBtn" text="关闭" prefWidth="80"/>
            <!-- 缩放按钮（可选） -->
            <Button text="放大" onAction="#zoomIn" prefWidth="80"/>
            <Button text="缩小" onAction="#zoomOut" prefWidth="80"/>
        </HBox>
    </bottom>
</BorderPane>