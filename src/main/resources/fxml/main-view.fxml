<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.photo.controller.MainController"
            styleClass="border-pane">
    <!-- 顶部工具栏 -->
    <top>
        <HBox spacing="10" styleClass="top-bar">
            <Label text="📸 电子图片管理程序" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Pane HBox.hgrow="ALWAYS"/>
        </HBox>
    </top>

    <!-- 中间主体区域 -->
    <center>
        <SplitPane dividerPositions="0.2">
            <!-- 左侧目录树 -->
            <TreeView fx:id="directoryTree" prefWidth="200"/>
            <!-- 右侧图片预览区 -->
            <BorderPane>
                <top>
                    <Label fx:id="dirInfoLabel" style="-fx-padding: 8 12; -fx-font-size: 12px;"/>
                </top>
                <center>
                    <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background-color: transparent;">
                        <FlowPane fx:id="thumbnailPane" styleClass="thumbnail-pane"/>
                    </ScrollPane>
                </center>
            </BorderPane>
        </SplitPane>
    </center>

    <!-- 底部提示信息区域 -->
    <bottom>
        <HBox styleClass="bottom-bar">
            <Label fx:id="tipLabel" HBox.hgrow="ALWAYS" />
        </HBox>
    </bottom>
</BorderPane>